<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= taller.nombre %> — Talleres Creativos</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav>
    <a class="logo" href="/">Talleres Creativos</a>
    <div><a href="/talleres">Talleres</a></div>
  </nav>

  <main>
    <div class="container">

      <a class="volver" href="/talleres">← Volver</a>

      <!-- Información del taller -->
      <h1><%= taller.nombre %></h1>
      <p class="precio">$<%= taller.precio %> MXN</p>

      <hr style="margin: 1.5rem 0; border: none; border-top: 1px solid #eee;">

      <!-- Placeholder de interés -->
      <h2>¿Te interesa?</h2>
      <p>Pon tu correo y te mandamos info.</p>
      <div style="max-width:380px;">
        <div class="form-group">
          <input type="email" placeholder="correo@ejemplo.com" disabled>
        </div>
        <button class="btn" disabled>Quiero información</button>
      </div>

    </div>
  </main>

</body>
</html>
