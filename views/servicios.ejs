<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Turismo Regional</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .tarjetas { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem; }
    .tarjeta { background: white; border: 1px solid #ddd; border-radius: 8px; padding: 1rem; width: 220px; }
    .tipo { font-size: 0.85rem; color: #666; text-transform: capitalize; }
    .precio { font-weight: bold; color: #0070f3; margin-top: 0.5rem; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Servicios Turísticos Regionales</h1>
    <p>Encuentra alojamientos, guías, artesanos y restaurantes locales.</p>
    <div class="tarjetas">
      <% servicios.forEach(s => { %>
        <div class="tarjeta">
          <h3><%= s.nombre %></h3>
          <p class="tipo"><%= s.tipo %></p>
          <p class="precio">$<%= s.precio %> MXN</p>
          <a href="/servicios/<%= s.id %>">Ver detalle</a>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
